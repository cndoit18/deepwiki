{
  "description": "Detects GitHub repository URLs in user prompts and suggests DeepWiki",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/deepwiki-detect.sh"
          }
        ]
      }
    ]
  }
}
